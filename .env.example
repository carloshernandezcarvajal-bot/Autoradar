# =====================
# Railway (Backend)
# =====================
# DATABASE_URL lo provee Railway automaticamente al agregar PostgreSQL plugin:
# Railway provee: postgresql://<user>:<pass>@<host>:<port>/<db>
# La app espera:   postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>
# Agregar el prefijo "+asyncpg" en Railway > Variables > DATABASE_URL
# Ejemplo en Railway:
#   DATABASE_URL = postgresql+asyncpg://<railway-provided-url>

SECRET_KEY=generar-con: openssl rand -hex 32
ENCRYPTION_KEY=generar-con: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=https://<frontend-vercel-url>.vercel.app
ENVIRONMENT=production

# =====================
# Vercel (Frontend)
# =====================
# Configurar en Vercel > Project Settings > Environment Variables:
#   NEXT_PUBLIC_API_URL = https://<backend-railway-url>.railway.app
